{
  "name": "@phughesmcr/anglicana",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./calendar": "./packages/calendar/mod.ts"
  },
  "license": "MIT",
  "publish": {
    "exclude": [
      "deno.lock",
      "packages/**/test/**/*",
      "packages/**/scratch/**/*",
      "packages/**/docs/**/*",
      "packages/**/dist/**/*",
      "packages/**/coverage/**/*",
      "packages/**/examples/**/*",
      "scratch/**/*"
    ]
  },
  "include": [
    "mod.ts",
    "packages/**/mod.ts",
    "packages/**/src/**/*.ts",
    "packages/**/test/**/*.ts",
    "packages/**/examples/**/*.ts"
  ],
  "exclude": [
    "packages/**/dist",
    "packages/**/docs",
    "packages/**/coverage",
    "packages/**/scratch",
    "packages/**/examples/vendor",
    ".cursor",
    ".github",
    ".vscode",
    "scratch"
  ],
  "imports": {
    "@/calendar/": "./packages/calendar/src/",
    "@hongminhee/deno-task-hooks": "jsr:@hongminhee/deno-task-hooks@^0.1.2",
    "@std/assert": "jsr:@std/assert@^1.0.13"
  },
  "lint": {
    "exclude": [
      "packages/**/dist/**/*",
      "packages/**/examples/vendor/*.js"
    ],
    "rules": {
      "tags": [
        "recommended",
        "jsr"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "*.md",
      "LICENSE",
      "packages/**/dist/**/*",
      "packages/**/docs/**/*"
    ],
    "lineWidth": 120,
    "newLineKind": "lf",
    "semiColons": true,
    "quoteProps": "consistent",
    "singleQuote": false,
    "useBraces": "whenNotSingleLine"
  },
  "test": {
    "include": [
      "packages/**/test/**/*.ts"
    ]
  },
  "tasks": {
    "build": "deno task check && deno task calendar:bundle",
    "check": "deno fmt --check && deno lint && deno check",
    "contribute": "deno task hooks:install",
    "hooks:install": "deno run --allow-read=deno.json,.git/hooks/ --allow-write=.git/hooks/ @hongminhee/deno-task-hooks",
    "hooks:pre-commit": "deno task check && deno fmt && deno task test",
    "test": "deno test --clean --parallel --hide-stacktraces",
    "calendar:browser-demo": "deno run --allow-net --allow-read=. packages/calendar/examples/serve-browser-demo.ts",
    "calendar:bundle": "deno bundle --minify --platform=browser --output=./packages/calendar/dist/anglicana_calendar.min.js ./packages/calendar/mod.ts"
  },
  "compilerOptions": {
    "strict": true,
    "erasableSyntaxOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
